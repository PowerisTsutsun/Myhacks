# =============================================================================
# MyHacks — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database — Neon Postgres
# Get this from your Neon project dashboard → Connection Details
# Use the "pooled" connection string for serverless/edge compatibility
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# -----------------------------------------------------------------------------
# Auth — JWT secret
# Generate a strong random secret: openssl rand -base64 32
# -----------------------------------------------------------------------------
JWT_SECRET="replace-with-a-strong-random-secret-at-least-32-chars"

# -----------------------------------------------------------------------------
# Admin seed (used by scripts/create-admin.ts)
# These credentials will be used to create the first admin account
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="changeme-strong-password"
SEED_ADMIN_NAME="MyHacks Admin"

# -----------------------------------------------------------------------------
# App URL (used for SEO/OG metadata and absolute URL generation)
# In production, set to your actual domain
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Email — Resend (required for 2FA, verification emails, and registration confirmation)
# Get your API key from resend.com → API Keys
# RESEND_FROM_EMAIL must be from a verified domain in your Resend account
# CONTACT_EMAIL is the inbox that receives contact form notifications
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="MyHacks <noreply@example.com>"
CONTACT_EMAIL="contact@example.com"

# -----------------------------------------------------------------------------
# OAuth — Google (console.cloud.google.com → Credentials → OAuth 2.0 Client ID)
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/oauth/google/callback
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# OAuth — Microsoft (portal.azure.com → App registrations → New registration)
# Supported account types: "Accounts in any organizational directory and personal Microsoft accounts"
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/oauth/microsoft/callback
# Under API permissions, add: User.Read
# -----------------------------------------------------------------------------
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Auth token TTLs (optional — sensible defaults are built in)
# EMAIL_VERIFICATION_TOKEN_TTL_MINUTES: default 1440 (24 hours)
# TWO_FACTOR_CODE_TTL_MINUTES: default 10 minutes
# -----------------------------------------------------------------------------
# EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
# TWO_FACTOR_CODE_TTL_MINUTES=10
